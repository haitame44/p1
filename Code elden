def creer_joueur():
    cls()
    titre("CRÉATION DU SANS-ÉCLAT")
    nom = input("  Nom de votre personnage : ").strip() or "Sans-Éclat"
    print()
    noms = list(CLASSES.keys())
    for i, (cn, cs) in enumerate(CLASSES.items(), 1):
        print(f"  [{i}] {cn:12s}  ❤{cs['pv']}  ⚔{cs['attaque']}  🛡{cs['defense']}")
        print(f"       {cs['desc']}\n")
    idx = choix(noms)
    cl = noms[idx]
    cs = CLASSES[cl]
    j = dict(
        nom=nom, classe=cl,
        pv=cs['pv'], pv_max=cs['pv'],
        stamina=cs['stamina'], stamina_max=cs['stamina'],
        attaque=cs['attaque'], defense=cs['defense'],
        runes=0, niveau=1, xp=0, xp_prochain=100,
        inventaire=["Estus Flask x5"],
        boss_tues=[], objets_cles=[],
        # flags narratifs
        serment_loup=False, alliance_ombre=False,
        foi_erdtree=False, sang_dragon=False, traître=False,
        melina_vivante=True, torrent=False,
        fin_choisie=None,
    )
    cls()
    lent(f"\n  Bienvenue, {nom} le {cl}. La Terre Entre vous appelle…")
    pause(2)
    return j

