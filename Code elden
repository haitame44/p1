            lent("\n  Vous n'avez pas assez de Runes. La sentinelle rigole.")
            pause(1)
            return "stormveil_entree"
    # c == 3
    lent("\n  Vous retournez vous entraîner dans les plaines.")
    # mini-donjon rapide
