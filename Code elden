def n_prologue(j):
    cls(); titre("PROLOGUE — L'APPEL DE LA GRÂCE")
    lent("  Vous vous réveillez dans une crypte souterraine.\n"
         "  Une voix douce résonne dans votre tête : celle de Mélina.\n"
         "  « Sans-Éclat... la grâce vous guide. Levez-vous. »\n"
         "  Deux chemins se présentent dès la sortie de la crypte.")
    pause(1)
    statut(j)
    print("  Un carrefour vous attend. Que faites-vous ?")
    c = choix([
        "Suivre la lumière d'or vers le nord (chemin de la Grâce)",
        "Descendre vers les ruines au sud (chemin de l'Ombre)",
        "Examiner la crypte avant de partir",
    ])
    if c == 0: return "limgrave_grace"
    if c == 1: return "ruines_ombre"
    # c == 2
    cls()
    lent("  Vous fouilllez la crypte. Derrière une dalle brisée,\n"
         "  vous trouvez un grimoire poussièreux et 150 Runes.")
    j['runes'] += 150
    ajouter_item(j, "Grimoire Ancestral")
    pause(1.5)
    print("\n  Maintenant, quelle direction ?")
    c2 = choix([
        "Vers le nord (chemin de la Grâce)",
        "Vers le sud (chemin de l'Ombre)",
    ])
    return "limgrave_grace" if c2 == 0 else "ruines_ombre"

