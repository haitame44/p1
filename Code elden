import time, random, os, sys

# ═══════════════════════════════════════════════
#  UTILITAIRES
# ═══════════════════════════════════════════════

def cls():
    os.system('cls' if os.name == 'nt' else 'clear')

def pause(s=1.0): time.sleep(s)

def lent(texte, d=0.025):
    for c in texte:
        print(c, end='', flush=True)
        time.sleep(d)
    print()

def titre(t):
    b = "═" * (len(t) + 4)
    print(f"\n  {b}\n  ║ {t} ║\n  {b}\n")

def bv(cur, mx, l=28, col="r"):
    r = int(l * cur / max(mx,1))
    bar = ("█" if col=="r" else "▓") * r + "░" * (l - r)
    return f"[{bar}] {cur}/{mx}"

def statut(j):
    print(f"\n  ┌─ {j['nom']} ─ Niv.{j['niveau']} ─ {j['classe']} ─────────────────")
    print(f"  │  ❤  Vie     : {bv(j['pv'], j['pv_max'])}")
    print(f"  │  ⚡ Stamina : {bv(j['stamina'], j['stamina_max'], col='g')}")
    print(f"  │  ⚔  ATK {j['attaque']}  🛡 DEF {j['defense']}  💰 {j['runes']} Runes  XP {j['xp']}/{j['xp_prochain']}")
    flags = []
    if j.get('serment_loup'):   flags.append("🐺 Serment du Loup")
    if j.get('alliance_ombre'): flags.append("🌑 Alliance Ombre")
    if j.get('foi_erdtree'):    flags.append("🌿 Foi Erdtree")
    if j.get('sang_dragon'):    flags.append("🔥 Sang Dragon")
    if j.get('traître'):        flags.append("💀 Traître")
    if flags: print(f"  │  {' | '.join(flags)}")
    print(f"  └──────────────────────────────────────────────────\n")

def choix(options):
    for i, o in enumerate(options, 1):
        print(f"  [{i}] {o}")
    while True:
        try:
            c = int(input("\n  ➤ "))
            if 1 <= c <= len(options): return c - 1
        except: pass
        print("  ❌ Invalide.")

def xp_up(j, xp, runes=0):
    j['xp'] += xp
    j['runes'] += runes
    print(f"\n  ✨ +{xp} XP  +{runes} Runes")
    while j['xp'] >= j['xp_prochain']:
        j['xp'] -= j['xp_prochain']
        j['niveau'] += 1
        j['xp_prochain'] = int(j['xp_prochain'] * 1.6)
        j['pv_max'] = int(j['pv_max'] * 1.18)
        j['pv'] = j['pv_max']
        j['attaque'] += 4
        j['defense'] += 2
        j['stamina_max'] += 12
        j['stamina'] = j['stamina_max']
        print(f"\n  🎉 NIVEAU {j['niveau']} ! ATK↑ DEF↑ PV Max : {j['pv_max']}")
    pause(1)

def soigner(j, pct=0.5):
    s = int(j['pv_max'] * pct)
    j['pv'] = min(j['pv_max'], j['pv'] + s)
    return s

def estus_dispo(j):
    for it in j['inventaire']:
        if 'Estus' in it: return True
    return False

def utiliser_estus(j):
    for i, it in enumerate(j['inventaire']):
        if 'Estus' in it:
            nb = int(it.split('x')[1])
            s = soigner(j)
            nb -= 1
            if nb <= 0: j['inventaire'].pop(i)
            else: j['inventaire'][i] = f"Estus Flask x{nb}"
            return s
    return 0

def ajouter_item(j, item):
    j['inventaire'].append(item)
    print(f"  🎁 Obtenu : {item}")

