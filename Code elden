def n_limgrave_grace(j):
    cls(); titre("🌿  LIMGRAVE — Plaines de la Grâce")
    lent("  Les plaines dorées de Limgrave s'étendent à perte de vue.\n"
         "  Un arbre lumineux domine l'horizon. Mélina apparaît à vos côtés.\n"
         "  « Je peux vous offrir Torrent, mon destrier spirituel. »")
    pause(1)
    statut(j)
    c = choix([
        "Accepter Torrent et aller vers Stormveil Castle",
        "Refuser Torrent et explorer seul à pied",
        "Demander à Mélina ce qu'elle sait de l'Anneau Brisé",
        "Chercher un campement de pillards signalé à l'est",
    ])
    if c == 0:
        j['torrent'] = True
        ajouter_item(j, "Sifflet de Torrent")
        lent("\n  Torrent surgit dans un souffle d'émeraude.\n"
             "  Vous êtes désormais le cavalier du vent.")
        pause(1)
        return "stormveil_entree"
    if c == 1:
        lent("\n  Mélina hoche la tête, respectueuse.\n"
             "  « Comme vous voudrez. Je reste à vos côtés. »")
        pause(1)
        return "stormveil_entree"
    if c == 2:
        cls()
        lent("  Mélina vous révèle que l'Anneau Brisé fut fragmenté\n"
             "  entre six demi-dieux lors de la Shattering.\n"
             "  « Rassemblez leurs Grandes Runes. Devenez Elden Lord. »\n"
             "  Vous gagnez une compréhension accrue de la Terre Entre.")
        xp_up(j, 30, 0)
        j['foi_erdtree'] = True
        pause(1)
        return "limgrave_grace"  # retour menu zone
    # c == 3
    cls()
    lent("  Le campement est plus grand que prévu.\n"
         "  Le chef des pillards vous repère.")
    victoire = combat(j, BOSS['pillard_chef'])
    if not victoire:
        lent("  Vous battez en retraite vers le site de grâce.")
        return "limgrave_grace"
    return "stormveil_entree"

def n_stormveil_entree(j):
    cls(); titre("🏰  STORMVEIL — Aux Portes")
    lent("  Les remparts de Stormveil se dressent, balayés par l'orage.\n"
         "  Un chevalier énorme bloque la porte principale : Margit.")
    pause(1)
    statut(j)
    c = choix([
        "Affronter Margit de front",
        "Chercher un passage secret sur le flanc gauche",
        "Soudoyer la sentinelle corrompue (200 Runes)",
        "Retourner à Limgrave s'entraîner",
    ])
    if c == 0:
        victoire = combat(j, BOSS['margit'])
        if not victoire: return "stormveil_entree"
        return "stormveil_interieur"
    if c == 1:
        cls()
        lent("  Vous découvrez une brèche dans les remparts.\n"
             "  Mais un Chevalier Rouge monte la garde.")
        lent("  Il vous aperçoit !")
        victoire = combat(j, BOSS['chevalier_rouge'])
        if not victoire: return "stormveil_entree"
        lent("\n  Vous passez sans affronter Margit.\n"
             "  Vous gardez l'avantage de la surprise à l'intérieur.")
        j['objets_cles'].append("Passage Secret")
        return "stormveil_interieur"
    if c == 2:
        if j['runes'] >= 200:
            j['runes'] -= 200
            lent("\n  La sentinelle accepte les Runes et vous ouvre une poterne.\n"
                 "  Vous pénétrez dans Stormveil sans combat.")
            return "stormveil_interieur"
