#  SYSTÈME DE COMBAT
# ═══════════════════════════════════════════════

def combat(j, boss, fuir_possible=True):
    """Retourne True = victoire, False = mort/fuite."""
    cls()
    titre(f"⚔  {boss['nom'].upper()}")
    lent(f"  {boss['description']}")
    pause(1.5)

    pv_b = boss['pv']
    pv_b_max = boss['pv']
    esquive = False
    tour = 0

    while pv_b > 0 and j['pv'] > 0:
        cls()
        print(f"\n  ══ COMBAT : {boss['nom']} ══")
        print(f"  🧑 {j['nom']}    {bv(j['pv'], j['pv_max'])}")
        print(f"  👹 {boss['nom']} {bv(pv_b, pv_b_max)}")
        print(f"  ⚡ Stamina      {bv(j['stamina'], j['stamina_max'], col='g')}")
        if pv_b < pv_b_max * 0.3:
            print("  ⚠  PHASE DE RAGE ACTIVÉE !")
        tour += 1
        print(f"  Tour {tour}\n")

        opts = [
            "Attaque normale",
            "Attaque puissante  (×1.9 / -20 stamina)",
            "Esquive & riposte  (-15 stamina)",
            f"Estus Flask {'✓' if estus_dispo(j) else '✗(épuisé)'}",
        ]
        if fuir_possible: opts.append("Fuir le combat")

        c = choix(opts)

        if c == 0:
            dmg = max(1, j['attaque'] + random.randint(-4, 6) - boss['def'])
            pv_b -= dmg
            j['stamina'] = max(0, j['stamina'] - 8)
            print(f"\n  ⚔  Coup normal : {dmg} dégâts !")
        elif c == 1:
            if j['stamina'] < 20:
                print("\n  💨 Stamina insuffisante !"); pause(1); continue
            dmg = max(1, int(j['attaque'] * 1.9) + random.randint(-2,5) - boss['def'])
            pv_b -= dmg
            j['stamina'] -= 20
            print(f"\n  🔥 Attaque puissante : {dmg} dégâts !")
        elif c == 2:
            if j['stamina'] < 15:
                print("\n  💨 Stamina insuffisante !"); pause(1); continue
            j['stamina'] -= 15
            esquive = True
            dmg = max(1, int(j['attaque'] * 1.4) - boss['def'])
            pv_b -= dmg
            print(f"\n  💨 Esquive + riposte : {dmg} dégâts !")
        elif c == 3:
            if estus_dispo(j):
                s = utiliser_estus(j)
                print(f"\n  🍶 Estus Flask : +{s} PV")
            else:
                print("\n  ❌ Plus d'Estus !"); pause(1); continue
        elif c == 4:
            if random.random() < 0.45:
                print("\n  🏃 Vous fuyez !"); pause(1); return False
            else:
                print("\n  ❌ Impossible de fuir !")

        # Regen stamina
        j['stamina'] = min(j['stamina_max'], j['stamina'] + 10)

        # Attaque boss
        if pv_b > 0:
            if esquive:
                print(f"\n  ✨ Attaque de {boss['nom']} esquivée !")
                esquive = False
            else:
                mult = 1.6 if pv_b < pv_b_max * 0.3 else 1.0
                crit = random.random() < boss.get('crit', 0.1)
                dmg_b = max(1, int((boss['atk'] * mult * (1.8 if crit else 1.0))
                                   + random.randint(-3, 5) - j['defense'] * 0.6))
                j['pv'] -= dmg_b
                pfx = "💥 CRITIQUE ! " if crit else "💥 "
                print(f"\n  {pfx}{boss['nom']} frappe : {dmg_b} dégâts !")
        pause(0.9)

    # Résultat
    if j['pv'] <= 0:
        cls(); titre("☠  VOUS ÊTES MORT")
        lent(f"  {boss['nom']} vous a vaincu. Vos Runes sont perdues.")
        j['runes'] = 0
        j['pv'] = max(1, int(j['pv_max'] * 0.25))
        pause(2); return False
    else:
        cls(); titre(f"🏆  {boss['nom'].upper()} VAINCU !")
        lent(f"\n  Vous avez triomphé de {boss['nom']} !")
        xp_up(j, boss['xp'], boss['xp'])
        if boss.get('loot'):
            ajouter_item(j, boss['loot'])
        if boss.get('cle'):
            j['objets_cles'].append(boss['cle'])
            print(f"  🔑 Objet clé : {boss['cle']}")
        j['boss_tues'].append(boss['nom'])
        pause(2); return True

