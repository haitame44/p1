    cls(); titre("👑  GODRICK LE GREFFÉ")
    lent("  Godrick se dresse sur son trône de membres volés.\n"
         "  « Un autre Sans-Éclat ? Parfait. J'ai besoin de nouvelles greffes ! »")
    pause(1)

    # Si le joueur a la Lettre de Pacte, option spéciale
